{
    "compilerOptions": {
        "target": "ES2025",
        "lib": ["ES2025", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "types": ["node"],
        "skipLibCheck": true
    },
    "include": ["src", "scripts"],
    "exclude": ["dist", "node_modules"]
}
